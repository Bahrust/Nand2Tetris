CHIP PC {
    IN in[16], reset, load, inc;
    OUT out[16];
    
    PARTS:
    Register(in=next, load=true, out=current);
    
    Inc16(in=current, out=incOut);
    
    Mux16(a=current, b=incOut, sel=inc, out=incOrHold);
    
    Mux16(a=incOrHold, b=in, sel=load, out=loadOrInc);
    
    Mux16(a=loadOrInc, b=false, sel=reset, out=next);
    
    Or16(a=current, b=false, out=out);
}